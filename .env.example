# ─────────────────────────────────────────────
#  LLM Provider  (pick one)
# ─────────────────────────────────────────────
# Option 1: OpenAI
# OPENAI_API_KEY=sk-...

# Option 2: OpenAI-compatible local server (e.g. Ollama, LM Studio)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama

# Option 3: Groq (OpenAI-compatible API)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
# You can use either OPENAI_API_KEY or GROQ_API_KEY
GROQ_API_KEY=

# ─────────────────────────────────────────────
#  Embedding model
# ─────────────────────────────────────────────
# "openai"  → text-embedding-3-small  (needs OPENAI_API_KEY)
# "local"   → all-MiniLM-L6-v2 via sentence-transformers (free, offline)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────
#  LLM model name
# ─────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
#  Vector store
# ─────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vectorstore
VECTOR_STORE_TYPE=faiss          # faiss | chroma

# ─────────────────────────────────────────────
#  RAG settings
# ─────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
# Default chunks per query; POST /chat can override per request with "k"
TOP_K_RETRIEVAL=12

# ─────────────────────────────────────────────
#  Fine-tuned model (optional)
# ─────────────────────────────────────────────
FINETUNED_MODEL_PATH=./data/finetuned_model
USE_FINETUNED_MODEL=false

# ─────────────────────────────────────────────
#  API
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
